{
  "name": "pdf-viewer-editor",
  "version": "0.7.10",
  "private": true,
  "description": "Cross-platform desktop PDF viewer + editor (Phase 7 polish — auto-update client + opt-in telemetry + WCAG 2.1 AA a11y + i18next localization + mac/linux config; all permissive OSS only)",
  "author": "PDF_Viewer_Editor swarm",
  "license": "MIT",
  "main": "dist/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.10.0 <21"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "start:built": "electron .",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"tests/**/*.ts\"",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "typecheck:preload": "tsc -p tsconfig.preload.json --noEmit",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "check:node": "node scripts/check-node.mjs",
    "pretest": "node scripts/check-node.mjs --strict",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "rebuild": "electron-builder install-app-deps",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "node scripts/rebuild-native-for-node.mjs",
    "rebuild:electron": "node scripts/rebuild-native-for-node.mjs --electron",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@napi-rs/canvas": "^1.0.0",
    "@reduxjs/toolkit": "^2.2.7",
    "@tesseract.js-data/eng": "^1.0.0",
    "asn1js": "^3.0.10",
    "better-sqlite3": "^11.1.2",
    "docx": "^9.7.1",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "i18next": "^26.3.0",
    "i18next-resources-to-backend": "^1.2.1",
    "node-forge": "^1.4.0",
    "node-signpdf": "^3.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.168",
    "pkijs": "^3.4.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.1.2",
    "tesseract.js": "^7.0.0",
    "utif": "^3.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.3",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^15.0.7",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^9.2.1",
    "electron": "^30.3.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "jsdom": "^24.1.1",
    "lint-staged": "^17.0.5",
    "playwright": "^1.45.3",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "_build_note": "electron-builder configuration lives in electron-builder.yml (not in this file). lint-staged config above is consumed by the .husky/pre-commit hook; see docs/build-report.md Backlog-Fix — Diego for the consistent-type-imports + tsc-after-autofix rationale."
}
