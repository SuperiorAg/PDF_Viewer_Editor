# Use the default Node prebuilds during `npm install` (fast, reliable).
# `postinstall` runs `electron-builder install-app-deps` which rebuilds
# native modules (better-sqlite3) against Electron 30's Node ABI separately.
# This split avoids forcing every transitive native dep to rebuild from
# source on a fresh install.
fund=false
audit-level=high

# Backlog-fix wave (Diego, 2026-05-28) — Node-version enforcement decision.
# `engines.node` in package.json is "{>=20.10.0 <21}" (matches .nvmrc + the CI
# matrix). That bound makes `npm install` emit a LOUD `npm warn EBADENGINE`
# warning on any non-20 Node (e.g. Node 24 dev hosts), surfacing the project's
# Node-20 expectation up front.
#
# We deliberately DO NOT set `engine-strict=true`. A hard engine block would
# make `npm ci` / `npm install` REFUSE to run on Node 24, which would strand the
# documented Node-24 escape hatch (`npm run rebuild:node`): that path needs a
# successful install first to populate the better-sqlite3 prebuild cache. The
# EBADENGINE warning + the explicit `scripts/check-node.mjs` guard (wired into
# `pretest`) give loud, actionable enforcement WITHOUT blocking install on the
# only Node available on this host. Do NOT add `engine-strict=true` unless this
# host gains Node 20 AND the escape hatch is retired. See docs/build-report.md
# "Backlog-Fix — Diego" + scripts/check-node.mjs for the full rationale.

# Phase 7 (Diego, Wave 29). The project pins vite@^5 (via electron-vite@2.3.0),
# but vite-plugin-static-copy@^4 declares a peer of vite@"^6 || ^7 || ^8". The
# combination is runtime-compatible (documented in LICENSES.md since Phase
# 4.1.1) but npm's strict peer resolver rejects it, so `npm ci` / `npm install`
# fail with ERESOLVE unless this flag is set. Prior phases passed --legacy-peer-
# deps on the CLI; pinning it here makes `npm ci` (CI, no CLI flag) resolve the
# same way the committed package-lock.json was generated, so the CI install
# step does not break. This does NOT mask a real conflict — the two packages
# are verified runtime-compatible; it only relaxes the peer-range strictness.
legacy-peer-deps=true
